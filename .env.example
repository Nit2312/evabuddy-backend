# === Groq (LLM) ===
GROQ_API_KEY=your_groq_api_key_here

# === HuggingFace (Embeddings + Cross-Encoder) ===
HF_TOKEN=your_huggingface_token_here

# === AstraDB (Vector Store) ===
ASTRA_DB_API_ENDPOINT=https://your-astra-db-endpoint.apps.astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:your_token_here
ASTRA_DB_ID=your_astra_db_id
ASTRA_DB_NAMESPACE=default_keyspace
ASTRA_DB_COLLECTION=rag_flask_data

# === RAG Config (optional - defaults shown) ===
RAG_FETCH_K=15
RAG_USE_TOP_K=8
RAG_RERANK_MAX=15
RAG_SKIP_RERANK=false

# === CORS - set this to your Vercel frontend URL ===
FRONTEND_URL=https://your-app.vercel.app

# === Data (only needed for local ingest) ===
DATA_FILE_PATH=10yearsdata.xls
